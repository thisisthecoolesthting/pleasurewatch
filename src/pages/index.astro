---
// PleasureWatch homepage — RefillWatch spine (HeroCompact + TrustStrip), intimacy-wellness copy.

import CompliantLayout from '@/layouts/CompliantLayout.astro';
import { getCollection } from 'astro:content';
import ProductCard from '@/components/ProductCard.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import HeroCompact from '@/components/HeroCompact.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import home from '@/data/spawn-home.json';

const h = home.homepage;
const b = home.brand;
const homeX = home as Record<string, any>;
const copy = (homeX.homepageCopy || {}) as Record<string, string>;
const categoryTiles = (homeX.categoryTiles || []) as Array<{
  key: string;
  title: string;
  excerpt: string;
  href: string;
}>;

const dmeta = homeX.defaultMetaDescription || b.taglineShort || '';
const authorSlug = homeX.defaultAuthorSlug || '_default';
const editorPseudonym = homeX.persona?.pseudonymHint || 'Alex Mercer';
const aboutHeadline = homeX.about?.headline || `Why ${b.shortName} exists`;
const aboutBody = homeX.about?.body || b.taglineLong || '';

const allProducts = await getCollection('products', ({ data }) => data.status === 'published');
const completeProducts = allProducts.filter((p) => {
  const d = p.data;
  const hasImage = d.imageUrl && !d.imageUrl.includes('example') && !d.imageUrl.startsWith('data:');
  const hasPrice = typeof d.price === 'number' && d.price > 0;
  const hasRating = typeof d.rating === 'number' && d.rating > 0;
  return hasImage && hasPrice && hasRating;
});
const compareRow = completeProducts
  .sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0))
  .slice(0, 3);

const allPillars = await getCollection('pillars', ({ data }) => data.status === 'published');
const pillarFour = allPillars
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt))
  .slice(0, 4);

type GridEntry = { kind: 'pillar'; entry: (typeof pillarFour)[0] } | { kind: 'tile'; tile: (typeof categoryTiles)[0] };
const gridEntries: GridEntry[] =
  pillarFour.length > 0
    ? pillarFour.map((entry) => ({ kind: 'pillar' as const, entry }))
    : categoryTiles.slice(0, 4).map((tile) => ({ kind: 'tile' as const, tile }));

const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const latestSix = allArticles
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt))
  .slice(0, 6);

const computedTrust = `${allArticles.length} buyer notes · ${allPillars.length} pillar guides · ${completeProducts.length} SKUs on the watchlist`;
const trustLineDisplay = (h.trustLine && String(h.trustLine).trim()) || computedTrust;

/** Pinterest 2:3 cards — zinc + pink editorial (no grocery-blue band). */
const pinThumbVariants = [
  'bg-gradient-to-b from-cream-200/80 to-terracotta-400/30',
  'bg-gradient-to-b from-terracotta-400/25 to-ink-900/90',
  'bg-gradient-to-b from-cream-100 to-cream-200',
  'bg-gradient-to-b from-terracotta-500/20 to-cream-50',
  'bg-gradient-to-b from-ink-900 to-terracotta-600/40',
  'bg-gradient-to-b from-cream-200 to-terracotta-400/20',
];

const dataStats = [
  {
    num: '68 dB',
    label: 'Quiet target',
    sub: 'We flag massagers louder than a normal conversation at 1 meter on full charge.',
  },
  {
    num: '90-day',
    label: 'Subscription check',
    sub: 'Reorder cadence logged before we call auto-ship a good deal.',
  },
  {
    num: `${completeProducts.length || '40'}+`,
    label: 'SKUs tracked',
    sub: 'Lube, massagers, couples kits, cleaners — retail purchase only.',
  },
];

const trustItems = [
  { label: 'Body-safe callouts', icon: 'shield' as const },
  { label: 'Noise & battery tests', icon: 'clock' as const },
  { label: 'No brand pay-to-play', icon: 'ban' as const },
];

const productBadges = ['Quiet value', 'Our pick', 'Premium build'] as const;
---

<CompliantLayout title={b.fullName} description={dmeta}>

  <HeroCompact
    eyebrow={h.eyebrow}
    h1={h.h1}
    subhead={h.subhead}
    ctaPrimaryHref={h.ctaPrimaryHref}
    ctaPrimaryLabel={h.ctaPrimaryLabel}
    ctaSecondaryHref={h.ctaSecondaryHref}
    ctaSecondaryLabel={h.ctaSecondaryLabel}
    bullets={[
      '18+ editorial only',
      'Retail purchase — no manufacturer samples',
      `${completeProducts.length} products on the watchlist`,
    ]}
    stats={dataStats}
    products={compareRow}
    articleCount={allArticles.length}
    gradient="bg-[radial-gradient(55%_90%_at_100%_0%,rgba(236,72,153,.18),transparent_50%),radial-gradient(45%_55%_at_0%_100%,rgba(24,24,27,.08),transparent_55%)]"
    snapshot={{
      panelLabel: 'PleasureWatch bench',
      panelAriaLabel: 'Intimacy wellness product watchlist',
      trackedSuffix: 'SKUs tracked',
      footerNote: 'Silicone grade · SPL noise · $/month with auto-ship',
      footerHref: '/pillars/buyers-guide',
      footerLinkText: 'Open buyers guide →',
      productPlaceholder: 'Pick',
    }}
    heroImageUrl={h.heroImageUrl}
    heroBadge="18+ · Independent reviews"
    heroCaption="Discreet editorial research — we buy at retail, publish material and noise notes, and math subscription boxes against one-time purchase."
    heroAlt="Soft editorial still life for intimacy wellness product research"
    rightPanel="image"
  />

  <TrustStrip trustLine={trustLineDisplay} items={trustItems} />

  {gridEntries.length > 0 && (
    <section class="max-w-6xl mx-auto px-5 py-12 md:py-14">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-8">
        <div>
          <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 font-medium mb-2">
            {copy.pillarKicker || 'Shop by topic'}
          </p>
          <h2 class="font-display text-3xl md:text-4xl text-ink-900 leading-tight !mt-0 max-w-[20ch]">
            {copy.pillarH2 || 'Four lanes we test every month'}
          </h2>
        </div>
        <p class="text-sm text-ink-700 max-w-[32ch]">
          {copy.pillarSub || 'Each lane has a buyer checklist, tracked SKUs, and picks we would buy at retail.'}
        </p>
      </div>
      <div class={`grid grid-cols-1 sm:grid-cols-2 gap-4 ${gridEntries.length >= 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3'}`}>
        {gridEntries.map((row, idx) => {
          const tints = [
            'bg-gradient-to-b from-cream-100 to-cream-50',
            'bg-gradient-to-b from-terracotta-400/12 to-cream-50',
            'bg-gradient-to-b from-cream-200/90 to-cream-50',
            'bg-gradient-to-b from-ink-900/[0.03] to-cream-50',
          ];
          const num = String(idx + 1).padStart(2, '0');
          const isPillar = row.kind === 'pillar';
          const title = isPillar ? row.entry.data.title : row.tile.title;
          const excerpt = isPillar ? row.entry.data.excerpt : row.tile.excerpt;
          const href = isPillar ? `/pillars/${row.entry.slug}` : row.tile.href;
          const kicker = isPillar ? 'Guide' : row.tile.key.replace(/-/g, ' ');
          return (
            <a
              href={href}
              class={`group no-underline relative overflow-hidden rounded-xl border border-cream-200 p-6 min-h-[240px] flex flex-col transition-all hover:-translate-y-1 hover:shadow-soft-lg hover:border-terracotta-400 ${tints[idx % tints.length]}`}
            >
              <p class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-terracotta-600">{num} · {kicker}</p>
              <h3 class="font-display text-xl text-ink-900 !mt-2 leading-snug">{title}</h3>
              <p class="text-sm text-ink-700 mt-2.5 leading-relaxed flex-1">{excerpt}</p>
              <span class="font-mono text-[11px] tracking-[0.1em] uppercase text-ink-900 mt-4 group-hover:text-terracotta-600">
                Open lane <span class="text-terracotta-500">→</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {compareRow.length >= 1 && (
    <section class="bg-gradient-to-b from-cream-50 to-cream-100 border-y border-cream-200">
      <div class="max-w-6xl mx-auto px-5 py-12 md:py-14">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-6">
          <div>
            <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 font-medium mb-2">
              {copy.productsKicker || 'Retail watchlist'}
            </p>
            <h2 class="font-display text-3xl md:text-4xl text-ink-900 !mt-0 leading-tight max-w-[22ch]">
              {copy.productsH2 || 'Top three on our bench right now'}
            </h2>
          </div>
          <p class="text-sm text-ink-700 max-w-[36ch]">
            {copy.productsSub || 'Ranked on materials, noise, battery, and monthly cost with subscription markup called out.'}
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {compareRow.map((p, i) => (
            <div class="relative">
              <span class="absolute z-10 top-3 left-3 bg-terracotta-500 text-white font-mono text-[10px] tracking-[0.14em] uppercase px-2.5 py-1 rounded shadow-soft">
                {productBadges[i] || 'Tracked'}
              </span>
              <ProductCard product={p} />
            </div>
          ))}
        </div>

        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mt-8 pt-6 border-t border-dashed border-cream-200">
          <p class="text-sm text-ink-700 max-w-[62ch]">
            <strong class="text-ink-900">Alex Mercer's protocol:</strong> retail buy, label read for silicone and plasticizers,
            SPL at 1m on full charge, 90-day subscription log — details on{' '}
            <a href="/how-we-test/" class="text-terracotta-600 hover:underline">how we test</a>.
          </p>
          <a href="/products/" class="font-mono text-[11.5px] tracking-[0.08em] uppercase text-ink-900 border-b border-terracotta-500 pb-0.5 no-underline hover:text-terracotta-600 whitespace-nowrap">
            All reviews →
          </a>
        </div>
      </div>
    </section>
  )}

  {latestSix.length > 0 ? (
    <section class="max-w-6xl mx-auto px-5 py-12 md:py-14">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-8">
        <div>
          <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 font-medium mb-2">
            {copy.articlesKicker || 'From the desk'}
          </p>
          <h2 class="font-display text-3xl md:text-4xl text-ink-900 !mt-0 leading-tight max-w-[18ch]">
            {copy.articlesH2 || 'Latest buyer notes'}
          </h2>
        </div>
        <a href="/articles" class="font-mono text-[11.5px] tracking-[0.08em] uppercase text-ink-900 border-b border-terracotta-500 pb-0.5 no-underline hover:text-terracotta-600 whitespace-nowrap">
          All articles →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestSix.map((a, i) => (
          <a href={`/articles/${a.slug}`} class="group no-underline block bg-white border border-cream-200 rounded-xl overflow-hidden hover:shadow-soft-lg hover:-translate-y-1 hover:border-terracotta-400 transition-all">
            <div class={`relative aspect-[2/3] overflow-hidden ${a.data.heroImage ? '' : pinThumbVariants[i % pinThumbVariants.length]}`}>
              {a.data.heroImage ? (
                <img src={a.data.heroImage} alt={a.data.title} loading="lazy"
                     class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500" />
              ) : (
                <div class={`absolute inset-0 p-6 flex flex-col justify-between ${i === 4 ? 'text-cream-50' : 'text-ink-900'}`}>
                  <span class={`font-mono text-[10.5px] tracking-[0.16em] uppercase ${i === 4 ? 'text-terracotta-400' : 'text-terracotta-600'}`}>
                    {(a.data.tags?.[0] || 'Buyer note')} · {a.data.readingTime || '7'} min
                  </span>
                  <h3 class={`font-display text-2xl leading-[1.08] max-w-[12ch] !mt-0 ${i === 4 ? 'text-cream-50' : 'text-ink-900'}`}>
                    {a.data.title}
                  </h3>
                </div>
              )}
            </div>
            <div class="p-5 flex flex-col gap-2.5">
              <p class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-terracotta-600">
                {a.data.tags?.[0] || 'Intimacy wellness'}
              </p>
              <h3 class="font-display text-lg text-ink-900 !mt-0 leading-snug group-hover:text-terracotta-600 transition-colors">
                {a.data.title}
              </h3>
              <div class="flex items-center gap-2.5 mt-auto pt-3 border-t border-cream-200 text-xs text-ink-500">
                <span class="inline-grid place-items-center w-6 h-6 rounded-full bg-terracotta-500 text-cream-50 font-display font-semibold text-[11px]">
                  {editorPseudonym[0]?.toUpperCase() || 'A'}
                </span>
                <span>{editorPseudonym} · {new Date(a.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  ) : (
    <section class="max-w-3xl mx-auto px-5 py-14 text-center">
      <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 mb-3">Buyer notes incoming</p>
      <h2 class="font-display text-2xl text-ink-900 !mt-0">Start with the flagship guide</h2>
      <p class="text-ink-700 mt-3 leading-relaxed">
        More articles are on the way. The buyers guide covers materials, noise, batteries, and subscription math today.
      </p>
      <a href="/pillars/buyers-guide" class="btn-primary inline-flex mt-6 no-underline">Read buyers guide →</a>
    </section>
  )}

  <section class="relative bg-ink-900 text-cream-50 py-16 md:py-20 overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none bg-[radial-gradient(55%_70%_at_12%_40%,rgba(236,72,153,.22),transparent_65%)]" />
    <div class="relative max-w-6xl mx-auto px-5 grid md:grid-cols-[280px_1fr] gap-10 md:gap-14 items-start">
      <a href={`/authors/${authorSlug}/`} class="block no-underline">
        <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-gradient-to-br from-terracotta-500 to-ink-900 shadow-soft-lg relative border border-cream-50/10">
          <img
            src={`/authors/${authorSlug}.svg`}
            onerror="this.style.display='none'"
            alt={editorPseudonym}
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover opacity-90"
          />
          <div class="absolute inset-0 grid place-items-center">
            <span class="font-display font-semibold text-7xl text-cream-50/90">A</span>
          </div>
          <span class="absolute bottom-3.5 right-3.5 bg-cream-50 text-ink-900 font-mono text-[10px] tracking-[0.12em] uppercase px-2.5 py-1 rounded">
            {editorPseudonym}
          </span>
        </div>
      </a>
      <div>
        <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-400 font-medium">
          {copy.authorKicker || 'About PleasureWatch'}
        </p>
        <h2 class="font-display text-3xl md:text-4xl !mt-3 leading-tight text-cream-50">{aboutHeadline}</h2>
        <p class="text-cream-50/80 text-base md:text-lg leading-relaxed mt-5 max-w-[56ch]">{aboutBody}</p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 md:gap-7 mt-8 pt-8 border-t border-cream-50/15">
          <div>
            <p class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-terracotta-400">Buyer notes</p>
            <p class="font-display text-3xl text-cream-50 mt-1.5 leading-none">{allArticles.length}</p>
            <p class="text-sm text-cream-50/65 mt-1.5">Bylined · dated · corrected within 72 hours.</p>
          </div>
          <div>
            <p class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-terracotta-400">SKUs on watchlist</p>
            <p class="font-display text-3xl text-cream-50 mt-1.5 leading-none">{completeProducts.length}</p>
            <p class="text-sm text-cream-50/65 mt-1.5">Amazon retail links · pleasurewatch-20 tag.</p>
          </div>
          <div>
            <p class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-terracotta-400">Pillar guides</p>
            <p class="font-display text-3xl text-cream-50 mt-1.5 leading-none">{allPillars.length}</p>
            <p class="text-sm text-cream-50/65 mt-1.5">Flagship buyers guide + expanding library.</p>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 mt-9">
          <a href="/how-we-test/" class="btn-primary no-underline">
            How we test <span aria-hidden="true" class="ml-2">→</span>
          </a>
          <a href={`/authors/${authorSlug}/`} class="inline-flex items-center justify-center rounded-full px-7 py-3 font-semibold text-base border border-cream-50/40 text-cream-50 transition-all hover:bg-cream-50 hover:text-ink-900 no-underline">
            About {editorPseudonym}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-5 py-10 md:py-12">
    <NewsletterForm
      variant="hero"
      title={homeX.newsletter?.title || 'The PleasureWatch weekly'}
      subtitle={homeX.newsletter?.subtitle || 'One material callout, one subscription warning, one pick we would buy — weekly. No spam.'}
      cta={copy.newsletterCta || 'Get the weekly watchlist'}
    />
  </section>

  <section class="bg-terracotta-400/10 border-y border-cream-200 py-12">
    <div class="max-w-6xl mx-auto px-5 grid md:grid-cols-[auto_1fr_auto] gap-6 md:gap-9 items-center">
      <div class="grid place-items-center w-16 h-16 rounded-full bg-terracotta-500 text-cream-50 font-display text-2xl font-semibold">18+</div>
      <div>
        <h3 class="font-display text-xl md:text-2xl text-ink-900 !mt-0 mb-1">
          Disclosures, testing standards, affiliate policy.
        </h3>
        <p class="text-sm md:text-[15px] text-ink-700 max-w-[60ch]">
          {copy.methodologyBlurb || '18+ only · affiliate disclosure on every money page · material and noise testing protocol.'}
        </p>
      </div>
      <a href="/disclosure/" class="btn-primary no-underline whitespace-nowrap">
        Read disclosures <span aria-hidden="true" class="ml-2">→</span>
      </a>
    </div>
  </section>

</CompliantLayout>
