---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';
import StickyAdBar from '@/components/StickyAdBar.astro';
import StickyProductBar from '@/components/StickyProductBar.astro';
import EmailCapture from '@/components/EmailCapture.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import AuthorByline from '@/components/AuthorByline.astro';
import MedicalDisclaimer from '@/components/MedicalDisclaimer.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import TopPicksBlock from '@/components/TopPicksBlock.astro';
import ProductSidebar from '@/components/ProductSidebar.astro';
import PhoneCasePromo from '@/components/PhoneCasePromo.astro';
import ArticleToC from '@/components/ArticleToC.astro';
import { getCollection, getEntry } from 'astro:content';
import { getRelatedProductsFromBody } from '@/utils/related-products';
import { siteOrigin } from '@/utils/site-origin';
import home from '@/data/spawn-home.json';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.status !== 'draft');
  return articles.map((a) => ({
    params: { slug: a.slug },
    props: { entry: a },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const b = home.brand;
const nl = home.newsletter;
const siteYmyl =
  (home as { editorial?: { ymyl?: boolean } }).editorial?.ymyl === true ||
  (home as { persona?: { ymyl?: boolean } }).persona?.ymyl === true;
const o = siteOrigin();
const editorialAuthor = (home as { editorial?: { author_slug?: string } }).editorial?.author_slug;
const defSlug =
  editorialAuthor || (home as { defaultAuthorSlug?: string }).defaultAuthorSlug || '_default';
const authorSlug = entry.data.author ?? defSlug;
const author = await getEntry('authors', authorSlug);
const relatedProducts = await getRelatedProductsFromBody(entry.body);
const topProduct = relatedProducts[0];
const publishedISO = new Date(entry.data.publishedAt).toISOString();
const modifiedISO = entry.data.updatedAt ? new Date(entry.data.updatedAt).toISOString() : undefined;
const bodyLower = (entry.body || '').toLowerCase();
const tags = (entry.data.tags || []).map((t) => t.toLowerCase());
const medicalTerms = [
  'hrt', 'hormone therapy', 'hormone replacement', 'estrogen', 'progesterone',
  'supplement', 'magnesium', 'melatonin', 'ssri', 'statin',
  'sleeping pill', 'sleep medication', 'insomnia', 'prescription',
];
const bodyHeuristic = medicalTerms.some((term) => bodyLower.includes(term));
const tagMatch = ['health', 'supplements', 'medication', 'hrt', 'hormones', 'insomnia'].some((k) =>
  tags.includes(k)
);
const customDisclaimer = (entry.data as { customDisclaimer?: boolean }).customDisclaimer === true;
const needsMedicalDisclaimer =
  siteYmyl && !customDisclaimer && (tagMatch || bodyHeuristic || siteYmyl);
const orgPub = b.fullName;
const orgUrl = o || (import.meta.env.SITE as string);
const personSchema = author
  ? {
      '@type': 'Person' as const,
      '@id': `${o}/authors/${author.slug}/#person`,
      name: author.data.name,
      url: `${o}/authors/${author.slug}/`,
      image: `${o}${author.data.photoUrl}`,
      jobTitle: author.data.role,
    }
  : { '@type': 'Organization' as const, name: orgPub, url: orgUrl };
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.metaDescription,
  datePublished: publishedISO,
  dateModified: modifiedISO ?? publishedISO,
  author: personSchema,
  publisher: { '@type': 'Organization', name: b.fullName, url: o },
  image: entry.data.heroImage ? [entry.data.heroImage] : undefined,
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${o}/articles/${entry.slug}/` },
};
const faqBlock = (entry.body || '').split(/^## FAQ/mi)[1] || '';
const faqPairs = faqBlock
  .split(/^### /m)
  .slice(1)
  .map((chunk) => {
    const nl = chunk.indexOf('\n');
    const q = (nl >= 0 ? chunk.slice(0, nl) : chunk).trim();
    const a = (nl >= 0 ? chunk.slice(nl + 1) : '').trim().split(/^## /m)[0]?.trim() || '';
    return q && a ? { q, a: a.slice(0, 500) } : null;
  })
  .filter(Boolean) as { q: string; a: string }[];
const faqSchema =
  faqPairs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqPairs.map(({ q, a }) => ({
          '@type': 'Question',
          name: q.endsWith('?') ? q : `${q}?`,
          acceptedAnswer: { '@type': 'Answer', text: a },
        })),
      }
    : null;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.metaDescription}
  image={entry.data.heroImage}
  ogType="article"
  articlePublishedTime={publishedISO}
  articleModifiedTime={modifiedISO}
  articleAuthor={author?.data.name ?? b.fullName}
  articleTags={entry.data.tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <div class="max-w-6xl mx-auto px-5 py-12 md:py-16 pb-20 flex gap-12 xl:gap-16 items-start">
    <ArticleToC />

    <article class="min-w-0 flex-1">
      <header class="mb-6">
        <h1 class="font-display text-3xl md:text-4xl text-ink-900 mb-3 !mt-0">{entry.data.title}</h1>
        <AffiliateDisclosure />
      </header>

      <AuthorByline
        authorSlug={authorSlug}
        publishedAt={entry.data.publishedAt}
        reviewedAt={entry.data.reviewedAt ?? entry.data.updatedAt}
      />

      <AdSlot position="above_fold" label="above-fold" />

      {entry.data.heroImage && (
        <figure class="mb-10 -mx-4 md:mx-0">
          <img
            src={entry.data.heroImage}
            alt={entry.data.title}
            loading="eager"
            class="w-full h-auto rounded-3xl object-cover aspect-[16/9] max-h-[480px] shadow-soft"
          />
        </figure>
      )}

      <AdSlot position="mid_content" label="pre-body" />

      <PhoneCasePromo placement="inline" />

      <div class="prose prose-lg prose-ink max-w-none">
        <Content />
      </div>

      <AdSlot position="end" label="post-body" />

      {needsMedicalDisclaimer && <MedicalDisclaimer />}

      {author && (
        <aside class="not-prose my-10 p-5 bg-cream-100 rounded-2xl border border-cream-200/60">
          <p class="text-sm text-ink-700 leading-relaxed">{author.data.shortBio}</p>
          <p class="text-sm mt-3">
            <a href={`/authors/${author.slug}/`} class="text-terracotta-600 hover:underline font-medium">
              About {author.data.name.split(' ')[0]} →
            </a>
            {' · '}
            <a href="/methodology/" class="text-terracotta-600 hover:underline">How we research →</a>
          </p>
        </aside>
      )}

      {relatedProducts.length >= 1 && (
        <div id="top-picks">
          <TopPicksBlock products={relatedProducts} />
        </div>
      )}
    </article>

    <div class="hidden xl:block w-52 flex-shrink-0">
      {relatedProducts.length > 0 && <ProductSidebar products={relatedProducts} />}
      <PhoneCasePromo placement="sidebar" />
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-5 pb-20">
    <EmailCapture title={nl.title} subtitle={nl.subtitle} />
    <NewsletterForm variant="inline" title={nl.title} subtitle={nl.subtitle} />
  </div>

  {topProduct ? <StickyProductBar product={topProduct} /> : <StickyAdBar />}
</BaseLayout>
