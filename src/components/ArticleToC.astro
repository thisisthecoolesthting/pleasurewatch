---
// No server-side props — JS builds ToC from live DOM H2s.
---

<nav
  id="article-toc"
  aria-label="Table of contents"
  class="hidden xl:block sticky top-24 self-start w-52 flex-shrink-0"
>
  <p class="font-mono text-[10px] tracking-[0.16em] uppercase text-terracotta-600 mb-3">On this page</p>
  <a
    id="toc-jump"
    href="#top-picks"
    class="hidden mb-3 block w-full text-center bg-terracotta-500 hover:bg-terracotta-600
           text-cream-50 font-mono text-[10.5px] tracking-[0.1em] uppercase
           px-3 py-2 rounded-full transition-colors no-underline"
  >
    ↓ Jump to picks
  </a>
  <ol id="toc-list" class="space-y-1 text-xs text-ink-700"></ol>
</nav>

<script>
(function () {
  const list = document.getElementById('toc-list');
  const jump = document.getElementById('toc-jump');
  if (!list) return;

  if (document.getElementById('top-picks')) jump?.classList.remove('hidden');

  const article = document.querySelector('article');
  const headings = article ? Array.from(article.querySelectorAll('h2')) : [];

  headings.forEach((h, i) => {
    if (!h.id) h.id = `s${i}`;
    const li = document.createElement('li');
    const a = document.createElement('a');
    a.href = `#${h.id}`;
    a.textContent = h.textContent ?? '';
    a.className =
      'block py-0.5 px-2 rounded transition-colors no-underline leading-snug ' +
      'text-ink-600 hover:text-terracotta-600 hover:bg-cream-100';
    li.appendChild(a);
    list.appendChild(li);
  });

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        const lnk = list.querySelector(`a[href="#${e.target.id}"]`);
        if (lnk) {
          lnk.classList.toggle('text-terracotta-600', e.isIntersecting);
          lnk.classList.toggle('font-semibold', e.isIntersecting);
        }
      });
    },
    { rootMargin: '-20% 0px -70% 0px' }
  );

  headings.forEach((h) => io.observe(h));
})();
</script>
